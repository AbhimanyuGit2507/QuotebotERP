// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageClassification {
  RFQ
  FOLLOWUP
  PO
  UNKNOWN
}

enum FollowupType {
  TECHNICAL
  NEGOTIATION
  DELIVERY
  GENERAL
}

enum AssistanceTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum PurchaseOrderStatus {
  DETECTED
  MATCHED
  REVIEW_PENDING
  APPROVED
  INVOICE_GENERATED
  INVOICE_SENT
  PAYMENT_PENDING
  PAID
  COMPLETED
  CANCELLED
  CLOSED
}

enum ConversationStage {
  NEW_RFQ
  QUOTE_GENERATED
  QUOTE_SENT
  FOLLOWUP_PENDING
  MANUAL_ASSISTANCE
  PO_RECEIVED
  PO_VERIFIED
  INVOICE_SENT
  PAYMENT_PENDING
  PAID
  CLOSED
}

enum EmailTemplateType {
  QUOTATION_EMAIL
  INVOICE_EMAIL
  PO_EMAIL
  INVOICE_PDF_HEADER
  INVOICE_PDF_FOOTER
}

// ============================================
// TENANCY & USERS
// ============================================

model Tenant {
  id              String    @id @default(cuid())
  company_name    String    @unique
  trading_name    String?
  plan            String    @default("basic")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  users           User[]
  products        Product[]
  product_categories ProductCategory[]
  clients         Client[]
  rfqs            RFQ[]
  quotations      Quotation[]
  invoices        Invoice[]
  payments        Payment[]
  accounting_integrations AccountingIntegration[]
  accounting_exports AccountingExport[]
  activities      Activity[]
  files           File[]
  analytics_cache AnalyticsCache[]
  audit_logs      AuditLog[]
  parse_runs      ParseRun[]
  conversations   Conversation[]
  messages        Message[]
  email_accounts  EmailAccount[]
  outbound_emails OutboundEmail[]
  settings_company SettingsCompany?
  settings_notifications SettingsNotifications?
  automation_rules AutomationRule[]
  integration_mappings IntegrationMapping[]
  purchase_orders AssistancePurchaseOrder[]
  assistance_tickets AssistanceTicket[]
  email_templates EmailTemplate[]

  @@index([company_name])
}

model Role {
  id              String    @id @default(cuid())
  name            String    @unique
  permissions_json String   @default("[]")
  created_at      DateTime  @default(now())

  users           User[]
}

model User {
  id              String    @id @default(cuid())
  tenant_id       String
  email           String    @unique
  password_hash   String
  name            String
  role_id         String
  status          String    @default("active")
  permissions     Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [role_id], references: [id])
  activities      Activity[]
  audit_logs      AuditLog[]
  messages        Message[]
  email_accounts  EmailAccount[]
  assigned_assistance_tickets AssistanceTicket[] @relation("AssistanceTicketAssignee")
  assigned_conversations Conversation[] @relation("ConversationAssignee")

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([role_id])
}

// ============================================
// PRODUCTS & CATEGORIES
// ============================================

model ProductCategory {
  id              String    @id @default(cuid())
  tenant_id       String
  name            String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  products        Product[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
}

model Product {
  id              String    @id @default(cuid())
  tenant_id       String
  sku             String
  name            String
  category_id     String
  unit            String
  price           Float
  cost            Float
  stock           Int       @default(0)
  reorder_level   Int       @default(10)
  hsn             String?
  gst_percent     Float     @default(18)
  description     String?
  status          String    @default("active")
  image_url       String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category        ProductCategory @relation(fields: [category_id], references: [id])
  rfq_items       RFQItem[]
  quotation_items QuotationItem[]

  @@unique([tenant_id, sku])
  @@index([tenant_id])
  @@index([category_id])
  @@index([status])
}

// ============================================
// CLIENTS
// ============================================

model Client {
  id              String    @id @default(cuid())
  tenant_id       String
  name            String
  type            String    // B2B or B2C
  email           String
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  gst             String?
  pan             String?
  tier            String    @default("regular")
  total_orders    Int       @default(0)
  total_value     Float     @default(0)
  last_order_date DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  rfqs            RFQ[]
  quotations      Quotation[]
  conversations   Conversation[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([tier])
  @@index([email])
}

// ============================================
// RFQs
// ============================================

model RFQ {
  id              String    @id @default(cuid())
  tenant_id       String
  number          String
  client_id       String
  channel         String    // email, whatsapp, manual
  priority        String    @default("medium")
  status          String    @default("pending")
  confidence_score Int     @default(0)
  due_date        DateTime?
  display_name    String?
  search_tokens   Json?
  quotation_id    String?   @unique
  conversation_id String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client          Client    @relation(fields: [client_id], references: [id])
  items           RFQItem[]
  quotation       Quotation? @relation(fields: [quotation_id], references: [id])
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, number])
  @@index([tenant_id])
  @@index([client_id])
  @@index([status])
  @@index([channel])
  @@index([conversation_id])
}

model RFQItem {
  id              String    @id @default(cuid())
  rfq_id          String
  product_id      String
  product_name    String
  quantity        Float
  unit            String
  notes           String?

  rfq             RFQ       @relation(fields: [rfq_id], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [product_id], references: [id])

  @@index([rfq_id])
  @@index([product_id])
}

// ============================================
// QUOTATIONS
// ============================================

model Quotation {
  id              String    @id @default(cuid())
  tenant_id       String
  number          String
  client_id       String
  display_name    String?
  search_tokens   Json?
  date            String    // YYYY-MM-DD
  valid_until     String    // YYYY-MM-DD
  subtotal        Float     @default(0)
  tax             Float     @default(0)
  total           Float     @default(0)
  status          String    @default("draft")
  terms_conditions String?
  conversation_id  String?
  sent_email_subject String?
  sent_email_body String?
  sent_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client          Client    @relation(fields: [client_id], references: [id])
  items           QuotationItem[]
  versions        QuotationVersion[]
  rfq             RFQ?
  invoices        Invoice[]
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  purchase_orders AssistancePurchaseOrder[]

  @@unique([tenant_id, number])
  @@index([tenant_id])
  @@index([client_id])
  @@index([status])
  @@index([conversation_id])
}

model QuotationItem {
  id              String    @id @default(cuid())
  quotation_id    String
  product_id      String
  product_name    String
  quantity        Float
  unit            String
  unit_price      Float
  tax_percent     Float
  total           Float
  notes           String?
  availability    String?
  available_quantity Float?

  quotation       Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [product_id], references: [id])

  @@index([quotation_id])
  @@index([product_id])
}

model QuotationVersion {
  id              String    @id @default(cuid())
  quotation_id    String
  version_number  Int
  snapshot_json   String    // JSON snapshot of quotation at this version
  created_at      DateTime  @default(now())

  quotation       Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@unique([quotation_id, version_number])
  @@index([quotation_id])
}

// ============================================
// ACTIVITIES & AUDIT
// ============================================

model Activity {
  id              String    @id @default(cuid())
  tenant_id       String
  entity_type     String    // 'Product', 'Client', 'RFQ', 'Quotation'
  entity_id       String
  action          String    // 'created', 'updated', 'deleted'
  user_id         String?
  created_at      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([entity_type])
  @@index([entity_id])
  @@index([created_at])
}

model AuditLog {
  id              String    @id @default(cuid())
  tenant_id       String
  user_id         String?
  action          String
  entity_type     String
  entity_id       String
  before_json     String?   // JSON of previous state
  after_json      String?   // JSON of new state
  created_at      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([entity_type])
  @@index([entity_id])
  @@index([created_at])
}

model ParseRun {
  id                  String    @id @default(cuid())
  tenant_id           String
  message_id          String?
  client_email        String?
  stage               String    // preview | create
  status              String    // success | partial | failed
  source              String?
  matched_count       Int       @default(0)
  unmatched_count     Int       @default(0)
  input_items_json    Json?
  matched_items_json  Json?
  unmatched_items_json Json?
  error_message       String?
  created_at          DateTime  @default(now())

  tenant              Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([message_id])
  @@index([stage])
  @@index([status])
  @@index([created_at])
}

// ============================================
// INBOX & MESSAGING
// ============================================

model Conversation {
  id              String    @id @default(cuid())
  tenant_id       String
  client_id       String
  customer_email  String?
  customer_name   String?
  email_account_id String?   // linked EmailAccount if from email provider
  subject         String
  channel         String    // email, whatsapp
  status          String    @default("open") // open, closed, archived
  current_stage   ConversationStage @default(NEW_RFQ)
  assigned_operator_id String?
  thread_id       String?   // email thread ID for grouping
  rfq_id          String?   // linked RFQ if applicable
  quotation_id    String?   // linked Quotation if applicable
  unread_count    Int       @default(0)
  last_message_at DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  email_account   EmailAccount? @relation(fields: [email_account_id], references: [id], onDelete: SetNull)
  assigned_operator User? @relation("ConversationAssignee", fields: [assigned_operator_id], references: [id], onDelete: SetNull)
  messages        Message[]
  rfqs            RFQ[]
  quotations      Quotation[]
  purchase_orders AssistancePurchaseOrder[]
  invoices        Invoice[]
  assistance_tickets AssistanceTicket[]

  @@index([tenant_id])
  @@index([client_id])
  @@index([email_account_id])
  @@index([channel])
  @@index([thread_id])
  @@index([status])
  @@index([current_stage])
  @@index([assigned_operator_id])
  @@index([created_at])
}

model Message {
  id                  String    @id @default(cuid())
  conversation_id     String
  tenant_id           String
  sender_id           String?   // User ID if sent by internal user, null if from client
  sender_name         String    // Display name of sender
  sender_email        String    // Email of sender
  body                String    // Message content (plaintext or HTML)
  channel             String    // email, whatsapp
  recipients          String?
  is_read             Boolean   @default(false)
  
  // Email-specific fields
  external_id         String?   // Gmail message ID, SES ID, etc (for dedup)
  message_id_header   String?
  in_reply_to         String?
  references_header   String?
  email_account_id    String?   // EmailAccount this came from
  provider            String?   // gmail, ses, smtp, forward
  thread_id           String?   // Email thread ID for grouping
  raw_payload         Json?     // Full email headers/metadata from provider
  attachments_json    Json?
  
  // Processing state
  is_processed        Boolean   @default(false)
  processing_status   String    @default("pending") // pending | parsed | failed
  direction           String    @default("inbound") // inbound | outbound
  workflow_direction  MessageDirection @default(INBOUND)
  classification      MessageClassification @default(UNKNOWN)
  classification_confidence Float?
  followup_type       FollowupType?
  
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  tenant              Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender              User?        @relation(fields: [sender_id], references: [id], onDelete: SetNull)
  email_account       EmailAccount? @relation(fields: [email_account_id], references: [id], onDelete: SetNull)
  assistance_tickets  AssistanceTicket[]

  // DB-level dedup for provider webhooks/retries
  @@unique([email_account_id, external_id])
  @@index([conversation_id])
  @@index([tenant_id])
  @@index([sender_id])
  @@index([email_account_id])
  @@index([external_id])
  @@index([is_read])
  @@index([is_processed])
  @@index([processing_status])
  @@index([direction])
  @@index([workflow_direction])
  @@index([classification])
  @@index([followup_type])
  @@index([message_id_header])
  @@index([in_reply_to])
  @@index([references_header])
  @@index([created_at])
}

model AssistancePurchaseOrder {
  id               String    @id @default(cuid())
  tenant_id        String
  conversation_id  String
  quotation_id     String?
  invoice_id       String?
  po_number        String?
  extracted_data   Json?
  confidence       Float?
  status           PurchaseOrderStatus @default(DETECTED)
  sent_email_subject String?
  sent_email_body String?
  sent_at         DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  quotation        Quotation? @relation(fields: [quotation_id], references: [id], onDelete: SetNull)
  invoice          Invoice? @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([conversation_id])
  @@index([quotation_id])
  @@index([invoice_id])
  @@index([status])
}

model AssistanceTicket {
  id               String    @id @default(cuid())
  tenant_id        String
  conversation_id  String
  message_id       String
  type             FollowupType
  status           AssistanceTicketStatus @default(OPEN)
  assigned_to_id   String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  message          Message   @relation(fields: [message_id], references: [id], onDelete: Cascade)
  assigned_to      User?     @relation("AssistanceTicketAssignee", fields: [assigned_to_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([conversation_id])
  @@index([message_id])
  @@index([status])
  @@index([assigned_to_id])
}

// ============================================
// EMAIL MANAGEMENT
// ============================================

model EmailAccount {
  id              String    @id @default(cuid())
  tenant_id       String
  user_id         String
  
  provider        String    // gmail | ses | smtp | forward
  email_address   String
  
  // Credentials stored encrypted elsewhere; this is metadata
  credentials     Json?     // encrypted via external vault
  is_active       Boolean   @default(true)
  
  last_sync_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  messages        Message[]
  outbound_emails OutboundEmail[]
  
  @@unique([tenant_id, user_id, email_address])
  @@index([tenant_id])
  @@index([user_id])
  @@index([provider])
  @@index([is_active])
}

model OutboundEmail {
  id              String    @id @default(cuid())
  tenant_id       String
  email_account_id String
  
  to              Json      // ["client@abc.com"]
  cc              Json?     // ["cc@abc.com"]
  subject         String
  body            String    // HTML/plaintext body
  
  status          String    @default("pending") // pending | sent | failed
  provider        String?   // gmail | ses (determined by email_account)
  
  attempts        Int       @default(0)
  last_error      String?
  
  created_at      DateTime  @default(now())
  sent_at         DateTime?
  updated_at      DateTime  @updatedAt
  
  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  email_account   EmailAccount  @relation(fields: [email_account_id], references: [id], onDelete: Cascade)
  
  @@index([tenant_id])
  @@index([email_account_id])
  @@index([status])
  @@index([created_at])
}

// ============================================
// FILES
// ============================================

model File {
  id              String    @id @default(cuid())
  tenant_id       String
  filename        String
  mime_type       String
  size            Int
  storage_path    String
  created_at      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([created_at])
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsCache {
  id              String    @id @default(cuid())
  tenant_id       String
  metric_key      String
  metric_value_json String
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, metric_key])
  @@index([tenant_id])
}

// ============================================
// SETTINGS
// ============================================

model SettingsCompany {
  id              String    @id @default(cuid())
  tenant_id       String    @unique
  currency        String    @default("INR")
  logo_url        String?
  profile_json    Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model SettingsNotifications {
  id              String    @id @default(cuid())
  tenant_id       String    @unique
  new_rfq         Boolean   @default(true)
  quote_sent      Boolean   @default(true)
  quote_viewed    Boolean   @default(true)
  quote_accepted  Boolean   @default(true)
  quote_declined  Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model SettingsTemplate {
  id              String    @id @default(cuid())
  tenant_id       String
  template_key    String    // 'quote_template', 'rfq_response', 'email_signature'
  content         String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@unique([tenant_id, template_key])
  @@index([tenant_id])
}

model EmailTemplate {
  id              String    @id @default(cuid())
  tenant_id       String
  template_type   EmailTemplateType
  subject_template String
  body_template   String    @db.Text
  variables_help  Json?     // JSON object describing available variables
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, template_type])
  @@index([tenant_id])
  @@index([template_type])
}

model AutomationRule {
  id              String    @id @default(cuid())
  tenant_id       String
  name            String
  condition       String
  action          String
  active          Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

// ============================================
// INVOICES & PAYMENTS (basic AR tracking)
// ============================================

model Invoice {
  id              String    @id @default(cuid())
  tenant_id       String
  quotation_id    String?
  conversation_id String?
  number          String
  display_name    String?
  search_tokens   Json?
  date            String    // YYYY-MM-DD
  due_date        String?
  currency        String    @default("INR")
  subtotal        Float     @default(0)
  tax             Float     @default(0)
  total           Float     @default(0)
  status          String    @default("open") // open | paid | partial | cancelled
  paid_amount     Float     @default(0)
  sent_email_subject String?
  sent_email_body String?
  sent_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  quotation       Quotation? @relation(fields: [quotation_id], references: [id])
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  payments        Payment[]
  exports         AccountingExport[]
  purchase_orders AssistancePurchaseOrder[]

  @@index([tenant_id])
  @@index([quotation_id])
  @@index([conversation_id])
  @@index([status])
  @@unique([tenant_id, number])
}

model Payment {
  id              String    @id @default(cuid())
  tenant_id       String
  invoice_id      String
  amount          Float
  method          String?   // stripe|bank|cheque|cash
  external_id     String?
  created_at      DateTime  @default(now())
  processed_at    DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoice         Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([invoice_id])
}

model AccountingIntegration {
  id              String    @id @default(cuid())
  tenant_id       String
  provider        String    // xero | quickbooks
  access_token    String
  refresh_token   String?
  expires_at      DateTime?
  scope           String?
  realm_id        String?   // QuickBooks company realm
  tenant_external_id String? // Xero tenant id
  status          String    @default("connected")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, provider])
  @@index([tenant_id])
}

model AccountingExport {
  id              String    @id @default(cuid())
  tenant_id       String
  invoice_id      String
  provider        String    // xero | quickbooks
  status          String    @default("queued") // queued | success | failed
  request_json    Json?
  response_json   Json?
  external_id     String?
  error_message   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoice         Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([invoice_id])
  @@index([provider])
  @@index([status])
}

// Persistent external->local mappings for integrations
model IntegrationMapping {
  id            String   @id @default(cuid())
  tenant_id     String
  provider      String   // zoho | odoo | xero | quickbooks
  external_id   String
  local_entity  String   // 'Client' | 'Product' | 'Invoice' etc
  local_id      String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([provider, external_id])
  @@unique([tenant_id, provider, external_id, local_entity])
}