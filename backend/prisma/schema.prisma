// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageClassification {
  RFQ
  FOLLOWUP
  PO
  UNKNOWN
}

enum FollowupType {
  TECHNICAL
  NEGOTIATION
  DELIVERY
  GENERAL
}

enum AssistanceTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum PurchaseOrderStatus {
  DETECTED
  MATCHED
  REVIEW_PENDING
  APPROVED
  INVOICE_GENERATED
  INVOICE_SENT
  PAYMENT_PENDING
  PAID
  COMPLETED
  CANCELLED
  CLOSED
}

enum ConversationStage {
  NEW_RFQ
  QUOTE_GENERATED
  QUOTE_SENT
  FOLLOWUP_PENDING
  MANUAL_ASSISTANCE
  PO_RECEIVED
  PO_VERIFIED
  INVOICE_SENT
  PAYMENT_PENDING
  PAID
  CLOSED
}

enum EmailTemplateType {
  QUOTATION_EMAIL
  INVOICE_EMAIL
  PO_EMAIL
  INVOICE_PDF_HEADER
  INVOICE_PDF_FOOTER
}

// ============================================
// TENANCY & USERS
// ============================================

model Tenant {
  id              String    @id @default(cuid())
  company_name    String    @unique
  trading_name    String?
  plan            String    @default("basic")
  allow_public_registration Boolean @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  users           User[]
  products        Product[]
  product_categories ProductCategory[]
  clients         Client[]
  rfqs            RFQ[]
  quotations      Quotation[]
  invoices        Invoice[]
  payments        Payment[]
  accounting_integrations AccountingIntegration[]
  accounting_exports AccountingExport[]
  activities      Activity[]
  files           File[]
  analytics_cache AnalyticsCache[]
  audit_logs      AuditLog[]
  parse_runs      ParseRun[]
  conversations   Conversation[]
  messages        Message[]
  email_accounts  EmailAccount[]
  outbound_emails OutboundEmail[]
  bills           Bill[]
  settings_company SettingsCompany?
  settings_notifications SettingsNotifications?
  automation_rules AutomationRule[]
  integration_mappings IntegrationMapping[]
  purchase_orders AssistancePurchaseOrder[]
  assistance_tickets AssistanceTicket[]
  email_templates EmailTemplate[]
  tax_profiles TaxProfile[]
  chart_of_accounts ChartOfAccount[]
  journal_entries   JournalEntry[]
  suppliers Supplier[]
  purchase_orders_outbound PurchaseOrderOutbound[]
  goods_receipt_notes GoodsReceiptNote[]
  stock_movements StockMovement[]
  exchange_rates ExchangeRate[]
  item_match_runs ItemMatchRun[]
  item_aliases ItemAlias[]
  item_match_configs     ItemMatchConfig[]
  item_alias_proposals   ItemAliasProposal[]

  @@index([company_name])
}

model Role {
  id              String    @id @default(cuid())
  name            String    @unique
  permissions_json String   @default("[]")
  created_at      DateTime  @default(now())

  users           User[]
}

model User {
  id              String    @id @default(cuid())
  tenant_id       String
  email           String    @unique
  password_hash   String
  name            String
  role_id         String
  status          String    @default("active")
  permissions     Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [role_id], references: [id])
  activities      Activity[]
  audit_logs      AuditLog[]
  messages        Message[]
  email_accounts  EmailAccount[]
  assigned_assistance_tickets AssistanceTicket[] @relation("AssistanceTicketAssignee")
  assigned_conversations Conversation[] @relation("ConversationAssignee")

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([role_id])
}

// ============================================
// PRODUCTS & CATEGORIES
// ============================================

model ProductCategory {
  id              String    @id @default(cuid())
  tenant_id       String
  name            String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  products        Product[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
}

model Product {
  id              String    @id @default(cuid())
  tenant_id       String
  sku             String
  name            String
  category_id     String
  unit            String
  price           Decimal   @db.Decimal(12,2)
  cost            Decimal   @db.Decimal(12,2)
  stock           Int       @default(0)
  reorder_level   Int       @default(10)
  hsn             String?
  gst_percent     Decimal   @db.Decimal(5,2) @default(18)
  description     String?
  status          String    @default("active")
  image_url       String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category        ProductCategory @relation(fields: [category_id], references: [id])
  rfq_items       RFQItem[]
  quotation_items QuotationItem[]
  stock_movements StockMovement[]
  purchase_order_items PurchaseOrderOutboundItem[]
  grn_items       GoodsReceiptNoteItem[]

  @@unique([tenant_id, sku])
  @@index([tenant_id])
  @@index([category_id])
  @@index([status])
  @@index([deleted_at])
}

// ============================================
// CLIENTS
// ============================================

model Client {
  id              String    @id @default(cuid())
  tenant_id       String
  name            String
  type            String    // B2B or B2C
  email           String
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  gst             String?
  pan             String?
  tier            String    @default("regular")
  total_orders    Int       @default(0)
  total_value     Decimal   @db.Decimal(12,2) @default(0)
  last_order_date DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  rfqs            RFQ[]
  quotations      Quotation[]
  conversations   Conversation[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([tier])
  @@index([email])
  @@index([deleted_at])
}

// ============================================
// RFQs
// ============================================

model RFQ {
  id              String    @id @default(cuid())
  tenant_id       String
  number          String
  client_id       String
  channel         String    // email, whatsapp, manual
  priority        String    @default("medium")
  status          String    @default("pending")
  confidence_score Int     @default(0)
  due_date        DateTime?
  display_name    String?
  search_tokens   Json?
  quotation_id    String?   @unique
  conversation_id String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client          Client    @relation(fields: [client_id], references: [id])
  items           RFQItem[]
  quotation       Quotation? @relation(fields: [quotation_id], references: [id])
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, number])
  @@index([tenant_id])
  @@index([client_id])
  @@index([status])
  @@index([channel])
  @@index([conversation_id])
  @@index([deleted_at])
}

model RFQItem {
  id              String    @id @default(cuid())
  rfq_id          String
  product_id      String
  product_name    String
  quantity        Decimal   @db.Decimal(12,2)
  unit            String
  notes           String?
  deleted_at      DateTime?

  rfq             RFQ       @relation(fields: [rfq_id], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [product_id], references: [id])

  @@index([rfq_id])
  @@index([product_id])
  @@index([deleted_at])
}

// ============================================
// QUOTATIONS
// ============================================

model Quotation {
  id              String    @id @default(cuid())
  tenant_id       String
  number          String
  client_id       String
  display_name    String?
  search_tokens   Json?
  date            DateTime  @default(now())
  valid_until     DateTime?
  subtotal        Decimal   @db.Decimal(12,2) @default(0)
  tax             Decimal   @db.Decimal(12,2) @default(0)
  total           Decimal   @db.Decimal(12,2) @default(0)
  status          String    @default("draft")
  terms_conditions String?
  conversation_id  String?
  sent_email_subject String?
  sent_email_body String?
  sent_at         DateTime?
  approval_status    String   @default("not_required")
  approved_by        String?
  approved_at        DateTime?
  rejection_reason   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client          Client    @relation(fields: [client_id], references: [id])
  items           QuotationItem[]
  versions        QuotationVersion[]
  rfq             RFQ?
  invoices        Invoice[]
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  purchase_orders AssistancePurchaseOrder[]

  @@unique([tenant_id, number])
  @@index([tenant_id])
  @@index([client_id])
  @@index([status])
  @@index([conversation_id])
  @@index([deleted_at])
}

model QuotationItem {
  id              String    @id @default(cuid())
  quotation_id    String
  product_id      String
  product_name    String
  quantity        Decimal   @db.Decimal(12,2)
  unit            String
  unit_price      Decimal   @db.Decimal(12,2)
  tax_percent     Decimal   @db.Decimal(5,2)
  total           Decimal   @db.Decimal(12,2)
  notes           String?
  availability    String?
  available_quantity Decimal? @db.Decimal(12,2)
  deleted_at      DateTime?

  quotation       Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [product_id], references: [id])

  @@index([quotation_id])
  @@index([product_id])
  @@index([deleted_at])
}

model QuotationVersion {
  id              String    @id @default(cuid())
  quotation_id    String
  version_number  Int
  snapshot_json   String    // JSON snapshot of quotation at this version
  created_at      DateTime  @default(now())

  quotation       Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)

  @@unique([quotation_id, version_number])
  @@index([quotation_id])
}

// ============================================
// ACTIVITIES & AUDIT
// ============================================

model Activity {
  id              String    @id @default(cuid())
  tenant_id       String
  entity_type     String    // 'Product', 'Client', 'RFQ', 'Quotation'
  entity_id       String
  action          String    // 'created', 'updated', 'deleted'
  user_id         String?
  created_at      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([entity_type])
  @@index([entity_id])
  @@index([created_at])
}

model AuditLog {
  id              String    @id @default(cuid())
  tenant_id       String
  user_id         String?
  action          String
  entity_type     String
  entity_id       String
  before_json     String?   // JSON of previous state
  after_json      String?   // JSON of new state
  created_at      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([entity_type])
  @@index([entity_id])
  @@index([created_at])
}

model ParseRun {
  id                  String    @id @default(cuid())
  tenant_id           String
  message_id          String?
  client_email        String?
  stage               String    // preview | create
  status              String    // success | partial | failed
  source              String?
  matched_count       Int       @default(0)
  unmatched_count     Int       @default(0)
  input_items_json    Json?
  matched_items_json  Json?
  unmatched_items_json Json?
  error_message       String?
  created_at          DateTime  @default(now())

  tenant              Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([message_id])
  @@index([stage])
  @@index([status])
  @@index([created_at])
}

// ============================================
// INBOX & MESSAGING
// ============================================

model Conversation {
  id              String    @id @default(cuid())
  tenant_id       String
  client_id       String
  customer_email  String?
  customer_name   String?
  email_account_id String?   // linked EmailAccount if from email provider
  subject         String
  channel         String    // email, whatsapp
  status          String    @default("open") // open, closed, archived
  current_stage   ConversationStage @default(NEW_RFQ)
  assigned_operator_id String?
  thread_id       String?   // email thread ID for grouping
  rfq_id          String?   // linked RFQ if applicable
  quotation_id    String?   // linked Quotation if applicable
  unread_count    Int       @default(0)
  last_message_at DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  email_account   EmailAccount? @relation(fields: [email_account_id], references: [id], onDelete: SetNull)
  assigned_operator User? @relation("ConversationAssignee", fields: [assigned_operator_id], references: [id], onDelete: SetNull)
  messages        Message[]
  rfqs            RFQ[]
  quotations      Quotation[]
  purchase_orders AssistancePurchaseOrder[]
  invoices        Invoice[]
  assistance_tickets AssistanceTicket[]

  @@index([tenant_id])
  @@index([client_id])
  @@index([email_account_id])
  @@index([channel])
  @@index([thread_id])
  @@index([status])
  @@index([current_stage])
  @@index([assigned_operator_id])
  @@index([created_at])
}

model Message {
  id                  String    @id @default(cuid())
  conversation_id     String
  tenant_id           String
  sender_id           String?   // User ID if sent by internal user, null if from client
  sender_name         String    // Display name of sender
  sender_email        String    // Email of sender
  body                String    // Message content (plaintext or HTML)
  channel             String    // email, whatsapp
  recipients          String?
  is_read             Boolean   @default(false)
  
  // Email-specific fields
  external_id         String?   // Gmail message ID, SES ID, etc (for dedup)
  message_id_header   String?
  in_reply_to         String?
  references_header   String?
  email_account_id    String?   // EmailAccount this came from
  provider            String?   // gmail, ses, smtp, forward
  thread_id           String?   // Email thread ID for grouping
  raw_payload         Json?     // Full email headers/metadata from provider
  attachments_json    Json?
  
  // Processing state
  is_processed        Boolean   @default(false)
  processing_status   String    @default("pending") // pending | parsed | failed
  direction           String    @default("inbound") // inbound | outbound
  workflow_direction  MessageDirection @default(INBOUND)
  classification      MessageClassification @default(UNKNOWN)
  classification_confidence Float?
  followup_type       FollowupType?
  
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  tenant              Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  conversation        Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender              User?        @relation(fields: [sender_id], references: [id], onDelete: SetNull)
  email_account       EmailAccount? @relation(fields: [email_account_id], references: [id], onDelete: SetNull)
  assistance_tickets  AssistanceTicket[]

  // DB-level dedup for provider webhooks/retries
  bills              Bill[]
  @@unique([email_account_id, external_id])
  @@index([conversation_id])
  @@index([tenant_id])
  @@index([sender_id])
  @@index([email_account_id])
  @@index([external_id])
  @@index([is_read])
  @@index([is_processed])
  @@index([processing_status])
  @@index([direction])
  @@index([workflow_direction])
  @@index([classification])
  @@index([followup_type])
  @@index([message_id_header])
  @@index([in_reply_to])
  @@index([references_header])
  @@index([created_at])
}

model AssistancePurchaseOrder {
  id               String    @id @default(cuid())
  tenant_id        String
  conversation_id  String
  quotation_id     String?
  invoice_id       String?
  po_number        String?
  display_name     String?
  search_tokens    Json?
  extracted_data   Json?
  confidence       Float?
  status           PurchaseOrderStatus @default(DETECTED)
  sent_email_subject String?
  sent_email_body String?
  sent_at         DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  quotation        Quotation? @relation(fields: [quotation_id], references: [id], onDelete: SetNull)
  invoice          Invoice? @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([conversation_id])
  @@index([quotation_id])
  @@index([invoice_id])
  @@index([status])
}

model AssistanceTicket {
  id               String    @id @default(cuid())
  tenant_id        String
  conversation_id  String
  message_id       String
  type             FollowupType
  status           AssistanceTicketStatus @default(OPEN)
  assigned_to_id   String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  message          Message   @relation(fields: [message_id], references: [id], onDelete: Cascade)
  assigned_to      User?     @relation("AssistanceTicketAssignee", fields: [assigned_to_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([conversation_id])
  @@index([message_id])
  @@index([status])
  @@index([assigned_to_id])
}

// ============================================
// EMAIL MANAGEMENT
// ============================================

model EmailAccount {
  id              String    @id @default(cuid())
  tenant_id       String
  user_id         String
  
  provider        String    // gmail | ses | smtp | forward
  email_address   String
  
  // Credentials stored encrypted elsewhere; this is metadata
  credentials     Json?     // encrypted via external vault
  is_active       Boolean   @default(true)
  
  last_sync_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  messages        Message[]
  outbound_emails OutboundEmail[]
  
  @@unique([tenant_id, user_id, email_address])
  @@index([tenant_id])
  @@index([user_id])
  @@index([provider])
  @@index([is_active])
}

model OutboundEmail {
  id              String    @id @default(cuid())
  tenant_id       String
  email_account_id String
  
  to              Json      // ["client@abc.com"]
  cc              Json?     // ["cc@abc.com"]
  subject         String
  body            String    // HTML/plaintext body
  
  status          String    @default("pending") // pending | sent | failed
  provider        String?   // gmail | ses (determined by email_account)
  
  attempts        Int       @default(0)
  last_error      String?
  
  created_at      DateTime  @default(now())
  sent_at         DateTime?
  updated_at      DateTime  @updatedAt
  
  tenant          Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  email_account   EmailAccount  @relation(fields: [email_account_id], references: [id], onDelete: Cascade)
  
  @@index([tenant_id])
  @@index([email_account_id])
  @@index([status])
  @@index([created_at])
}

// ============================================
// FILES
// ============================================

model File {
  id              String    @id @default(cuid())
  tenant_id       String
  filename        String
  mime_type       String
  size            Int
  storage_path    String
  created_at      DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([created_at])
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsCache {
  id              String    @id @default(cuid())
  tenant_id       String
  metric_key      String
  metric_value_json String
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, metric_key])
  @@index([tenant_id])
}

// ============================================
// SETTINGS
// ============================================

model SettingsCompany {
  id              String    @id @default(cuid())
  tenant_id       String    @unique
  currency        String    @default("INR")
  logo_url        String?
  profile_json    Json?
  quotation_approval_threshold Decimal? @db.Decimal(12,2)
  company_gstin   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model SettingsNotifications {
  id              String    @id @default(cuid())
  tenant_id       String    @unique
  new_rfq         Boolean   @default(true)
  quote_sent      Boolean   @default(true)
  quote_viewed    Boolean   @default(true)
  quote_accepted  Boolean   @default(true)
  quote_declined  Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model ProcessingSettings {
  id                        String   @id
  interval_ms               Int      @default(20000)
  run_batch_limit           Int      @default(60)
  classifier_batch_size     Int      @default(8)
  classifier_batch_max_bytes Int      @default(26000)
  extraction_delay_ms       Int      @default(50)
  llm_rate_limit_per_minute  Int      @default(10)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
}

model ItemMatchRun {
  id            String   @id @default(cuid())
  item_id       String?
  tenant_id     String
  input_text    String
  stage_used    String
  best_match_id String?
  confidence    Decimal? @db.Decimal(5,4)
  auto_applied  Boolean  @default(false)
  created_at    DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  candidates    ItemMatchCandidate[]
  feedbacks     ItemMatchFeedback[]

  @@index([tenant_id, created_at])
  @@index([item_id])
}

model ItemMatchCandidate {
  id          String   @id @default(cuid())
  run_id      String
  product_id  String?
  score       Decimal  @db.Decimal(6,4)
  rank        Int
  reason_json Json?
  created_at  DateTime @default(now())

  run         ItemMatchRun @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id, rank])
  @@index([product_id])
}

model ItemAlias {
  id                   String   @id @default(cuid())
  tenant_id            String
  alias_text           String
  canonical_product_id String
  source               String
  weight               Decimal  @db.Decimal(6,4) @default(1)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  tenant               Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, alias_text, canonical_product_id])
  @@index([tenant_id, alias_text])
}

model ItemMatchFeedback {
  id                  String   @id @default(cuid())
  run_id              String
  selected_product_id String?
  reviewer_id         String?
  action              String
  notes               String?
  created_at          DateTime @default(now())

  run                 ItemMatchRun @relation(fields: [run_id], references: [id], onDelete: Cascade)

  @@index([run_id, created_at])
  @@index([reviewer_id])
}

model ItemMatchConfig {
  id                           String   @id @default(cuid())
  tenant_id                    String   @unique
  suggestion_threshold         Decimal  @db.Decimal(5,4) @default(0.8)
  auto_accept_threshold        Decimal  @db.Decimal(5,4) @default(0.92)
  mode                         String   @default("manual")
  model_version                String   @default("v1")
  semantic_reranker_enabled    Boolean  @default(false)
  semantic_model_name          String   @default("all-MiniLM-L6-v2")
  semantic_weight              Decimal  @db.Decimal(3,2) @default(0.5)
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  tenant                       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

model ItemAliasProposal {
  id                     String   @id @default(cuid())
  tenant_id              String
  input_text             String
  canonical_product_id   String
  confidence             Decimal  @db.Decimal(5,4)
  feedback_count         Int      @default(1)
  status                 String   @default("pending") // "pending" | "accepted" | "rejected"
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  tenant                 Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, input_text, canonical_product_id])
  @@index([tenant_id, status, created_at])
  @@index([tenant_id, status])
}

model SettingsTemplate {
  id              String    @id @default(cuid())
  tenant_id       String
  template_key    String    // 'quote_template', 'rfq_response', 'email_signature'
  content         String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@unique([tenant_id, template_key])
  @@index([tenant_id])
}

model EmailTemplate {
  id              String    @id @default(cuid())
  tenant_id       String
  template_type   EmailTemplateType
  subject_template String
  body_template   String    @db.Text
  variables_help  Json?     // JSON object describing available variables
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, template_type])
  @@index([tenant_id])
  @@index([template_type])
}

model AutomationRule {
  id              String    @id @default(cuid())
  tenant_id       String
  name            String
  condition       String
  action          String
  active          Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
}

// ============================================
// TAX PROFILES
// ============================================

model TaxProfile {
  id          String   @id @default(cuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  name        String
  type        String   // "GST", "VAT", "SALES_TAX"
  rate        Decimal  @db.Decimal(5,2)
  hsn_code    String?
  is_default  Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  @@index([tenant_id])
  @@unique([tenant_id, name])
  @@index([deleted_at])
}

// ============================================
// INVOICES & PAYMENTS (basic AR tracking)
// ============================================

model Invoice {
  id              String    @id @default(cuid())
  tenant_id       String
  quotation_id    String?
  conversation_id String?
  number          String
  display_name    String?
  search_tokens   Json?
  date            DateTime  @default(now())
  due_date        DateTime?
  currency        String    @default("INR")
  subtotal        Decimal   @db.Decimal(12,2) @default(0)
  tax             Decimal   @db.Decimal(12,2) @default(0)
  total           Decimal   @db.Decimal(12,2) @default(0)
  status          String    @default("open") // open | paid | partial | cancelled
  paid_amount     Decimal   @db.Decimal(12,2) @default(0)
  payment_status  String    @default("unpaid")
  sent_email_subject String?
  sent_email_body String?
  sent_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  quotation       Quotation? @relation(fields: [quotation_id], references: [id])
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  payments        Payment[]
  exports         AccountingExport[]
  purchase_orders AssistancePurchaseOrder[]

  @@index([tenant_id])
  @@index([quotation_id])
  @@index([conversation_id])
  @@index([status])
  @@unique([tenant_id, number])
  @@index([deleted_at])
}

model Bill {
  id              String    @id @default(cuid())
  tenant_id       String
  message_id      String
  from_email      String
  subject         String
  invoice_number  String?
  amount          Decimal?  @db.Decimal(12,2)
  currency        String?
  due_date        DateTime?
  confidence      Float     @default(0)
  raw_extract     Json?
  status          String    @default("DETECTED") // DETECTED | REVIEW_PENDING | CONFIRMED | PAID
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  message         Message?  @relation(fields: [message_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([message_id])
  @@index([status])
}

model Payment {
  id              String    @id @default(cuid())
  tenant_id       String
  invoice_id      String
  amount          Decimal   @db.Decimal(12,2)
  method          String?   // stripe|bank|cheque|cash
  external_id     String?
  payment_method  String?   // "bank_transfer", "cash", "cheque", "upi", "card"
  reference_number String?
  notes           String?
  status          String    @default("completed")
  created_at      DateTime  @default(now())
  processed_at    DateTime?
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoice         Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([invoice_id])
}

model AccountingIntegration {
  id              String    @id @default(cuid())
  tenant_id       String
  provider        String    // xero | quickbooks
  access_token    String
  refresh_token   String?
  expires_at      DateTime?
  scope           String?
  realm_id        String?   // QuickBooks company realm
  tenant_external_id String? // Xero tenant id
  status          String    @default("connected")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, provider])
  @@index([tenant_id])
}

model AccountingExport {
  id              String    @id @default(cuid())
  tenant_id       String
  invoice_id      String
  provider        String    // xero | quickbooks
  status          String    @default("queued") // queued | success | failed
  request_json    Json?
  response_json   Json?
  external_id     String?
  error_message   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoice         Invoice   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([invoice_id])
  @@index([provider])
  @@index([status])
}

// Persistent external->local mappings for integrations
model IntegrationMapping {
  id            String   @id @default(cuid())
  tenant_id     String
  provider      String   // zoho | odoo | xero | quickbooks
  external_id   String
  local_entity  String   // 'Client' | 'Product' | 'Invoice' etc
  local_id      String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([provider, external_id])
  @@unique([tenant_id, provider, external_id, local_entity])
}

// ============================================
// DOUBLE-ENTRY ACCOUNTING
// ============================================

model ChartOfAccount {
  id          String   @id @default(uuid())
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id])
  code        String
  name        String
  type        String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parent_id   String?
  parent      ChartOfAccount? @relation("AccountHierarchy", fields: [parent_id], references: [id])
  children    ChartOfAccount[] @relation("AccountHierarchy")
  is_system   Boolean  @default(false)
  is_active   Boolean  @default(true)
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?
  journal_debits  JournalEntry[] @relation("DebitAccount")
  journal_credits JournalEntry[] @relation("CreditAccount")
  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([deleted_at])
}

model JournalEntry {
  id              String   @id @default(uuid())
  tenant_id       String
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  entry_number    String
  date            DateTime @default(now())
  description     String
  debit_account_id  String
  debit_account     ChartOfAccount @relation("DebitAccount", fields: [debit_account_id], references: [id])
  credit_account_id String
  credit_account    ChartOfAccount @relation("CreditAccount", fields: [credit_account_id], references: [id])
  amount          Decimal  @db.Decimal(12, 2)
  reference_type  String?  // INVOICE, PAYMENT, MANUAL
  reference_id    String?
  is_auto         Boolean  @default(false)
  created_by      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?
  @@index([tenant_id])
  @@index([tenant_id, date])
  @@index([reference_type, reference_id])
  @@index([deleted_at])
}

// ============================================
// SUPPLIERS
// ============================================

model Supplier {
  id              String   @id @default(uuid())
  tenant_id       String
  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  name            String
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  gstin           String?
  pan             String?
  contact_person  String?
  payment_terms   String?
  notes           String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?
  purchase_orders PurchaseOrderOutbound[]
  @@index([tenant_id])
  @@index([deleted_at])
}

// ============================================
// PURCHASE ORDERS (OUTBOUND)
// ============================================

model PurchaseOrderOutbound {
  id                String   @id @default(uuid())
  tenant_id         String
  tenant            Tenant   @relation(fields: [tenant_id], references: [id])
  number            String
  supplier_id       String
  supplier          Supplier @relation(fields: [supplier_id], references: [id])
  date              DateTime @default(now())
  expected_delivery DateTime?
  status            String   @default("draft")
  subtotal          Decimal  @db.Decimal(12, 2) @default(0)
  tax               Decimal  @db.Decimal(12, 2) @default(0)
  total             Decimal  @db.Decimal(12, 2) @default(0)
  currency          String   @default("INR")
  notes             String?
  created_by        String?
  approved_by       String?
  approved_at       DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  deleted_at        DateTime?
  items             PurchaseOrderOutboundItem[]
  grns              GoodsReceiptNote[]
  @@index([tenant_id])
  @@index([deleted_at])
}

model PurchaseOrderOutboundItem {
  id                String   @id @default(uuid())
  purchase_order_id String
  purchase_order    PurchaseOrderOutbound @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  product_id        String?
  product           Product? @relation(fields: [product_id], references: [id])
  product_name      String
  quantity          Decimal  @db.Decimal(12, 2)
  received_quantity Decimal  @db.Decimal(12, 2) @default(0)
  unit_price        Decimal  @db.Decimal(12, 2)
  tax_percent       Decimal  @db.Decimal(5, 2) @default(0)
  total             Decimal  @db.Decimal(12, 2)
  unit              String   @default("pcs")
}

// ============================================
// GOODS RECEIPT NOTES
// ============================================

model GoodsReceiptNote {
  id                String   @id @default(uuid())
  tenant_id         String
  tenant            Tenant   @relation(fields: [tenant_id], references: [id])
  purchase_order_id String
  purchase_order    PurchaseOrderOutbound @relation(fields: [purchase_order_id], references: [id])
  number            String
  date              DateTime @default(now())
  notes             String?
  received_by       String?
  created_at        DateTime @default(now())
  items             GoodsReceiptNoteItem[]
  @@index([tenant_id])
}

model GoodsReceiptNoteItem {
  id                String   @id @default(uuid())
  grn_id            String
  grn               GoodsReceiptNote @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  product_id        String?
  product           Product? @relation(fields: [product_id], references: [id])
  product_name      String
  quantity_received Decimal  @db.Decimal(12, 2)
  quantity_accepted Decimal  @db.Decimal(12, 2)
  quantity_rejected Decimal  @db.Decimal(12, 2) @default(0)
  notes             String?
}

// ============================================
// STOCK MOVEMENTS
// ============================================

model StockMovement {
  id             String   @id @default(uuid())
  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  product_id     String
  product        Product  @relation(fields: [product_id], references: [id])
  type           String
  quantity       Decimal  @db.Decimal(12, 2)
  reference_type String?
  reference_id   String?
  notes          String?
  created_by     String?
  created_at     DateTime @default(now())
  @@index([tenant_id])
  @@index([product_id])
  @@index([created_at])
}

// ============================================
// EXCHANGE RATES
// ============================================

model ExchangeRate {
  id             String   @id @default(uuid())
  tenant_id      String
  tenant         Tenant   @relation(fields: [tenant_id], references: [id])
  from_currency  String
  to_currency    String
  rate           Decimal  @db.Decimal(12, 6)
  effective_date DateTime @default(now())
  created_at     DateTime @default(now())
  @@index([tenant_id, from_currency, to_currency])
}