# Quotebot Backend - Environment Variables Template
# Copy this file to .env and update values for your environment

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL Connection String
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quotebot_db"

# ============================================
# JWT CONFIGURATION
# ============================================
# Secret key for signing JWT tokens
# IMPORTANT: Use a strong random string (minimum 32 characters) in production
# Generate one with: openssl rand -base64 32
JWT_SECRET=dev-secret-do-not-use-in-production

# Token expiration time
# Supported formats: "2h", "24h", "7d", or seconds number
JWT_EXPIRATION="24h"

# Refresh token secret and expiration
# Leave secret blank to reuse JWT_SECRET in development
JWT_REFRESH_SECRET=dev-refresh-secret-do-not-use-in-production
JWT_REFRESH_EXPIRATION="14d"

# Cookie settings for auth tokens
# AUTH_COOKIE_DOMAIN can be blank for localhost
AUTH_COOKIE_DOMAIN=""
# Set true when using https in production
AUTH_COOKIE_SECURE="false"
# lax | strict | none
AUTH_COOKIE_SAMESITE="lax"

# ============================================
# API CONFIGURATION
# ============================================
# Port the API server will listen on
API_PORT=3001

# Base path prefix for all API routes
# With this setting, endpoints will be at /api/...
API_PREFIX="api"

# CORS allowed origins (comma-separated)
# Add your frontend URL here
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Internal automation auth (used by automation scripts -> backend calls)
INTERNAL_API_KEY="replace-with-strong-internal-key"

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Directory where uploaded files will be stored
# Create this directory if it doesn't exist, or update the path
UPLOAD_FOLDER="/tmp/quotebot-uploads"

# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# ============================================
# ENVIRONMENT
# ============================================
# Node environment
# Use "development" for local development with logging
# Use "production" for deployed instances
NODE_ENV="development"

# ============================================
# GMAIL OAUTH (EMAIL INTEGRATION)
# ============================================
# Values come from your Google OAuth client JSON file
GMAIL_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-google-oauth-client-secret"
GMAIL_REDIRECT_URI="http://localhost:3001/api/email-integrations/oauth/callback"

# ============================================
# GOOGLE OAUTH LOGIN (PLATFORM AUTH)
# ============================================
# Reuse the same Google OAuth client or provide a separate one for app sign-in
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"

# ============================================
# ACCOUNTING INTEGRATIONS (Xero / QuickBooks)
# ============================================
# Xero OAuth credentials
XERO_CLIENT_ID="your-xero-client-id"
XERO_CLIENT_SECRET="your-xero-client-secret"
XERO_TENANT_ID="your-xero-tenant-id"
XERO_REDIRECT_URI="http://localhost:3001/api/integrations/accounting/xero/callback"
XERO_SCOPES="offline_access accounting.transactions openid profile email"
XERO_SALES_ACCOUNT_CODE="200"

# QuickBooks OAuth credentials
QUICKBOOKS_CLIENT_ID="your-quickbooks-client-id"
QUICKBOOKS_CLIENT_SECRET="your-quickbooks-client-secret"
QUICKBOOKS_REALM_ID="your-quickbooks-realm-id"
QUICKBOOKS_REDIRECT_URI="http://localhost:3001/api/integrations/accounting/quickbooks/callback"
QUICKBOOKS_SCOPES="com.intuit.quickbooks.accounting openid profile email"

# ============================================
# LLM PROVIDERS (RFQ PIPELINE FALLBACK ORDER)
# ============================================
# Fallback order used by email-rfq service
# Default order in code is groq,mistral,gemini,openrouter,cerebras,together,deepseek
RFQ_LLM_FALLBACK_ORDER="groq,mistral,gemini,openrouter,cerebras,together,deepseek"

# RFQ classifier snippet tuning (helps pack more emails per LLM call)
RFQ_CLASSIFIER_SNIPPET_HEAD_CHARS=200
RFQ_CLASSIFIER_SNIPPET_MAX_CHARS=600
RFQ_CLASSIFIER_KEYWORD_WINDOW_CHARS=40
RFQ_CLASSIFIER_MAX_WINDOWS=4
RFQ_CLASSIFIER_MAX_BATCH_BYTES=26000

# RFQ timing metrics window (days)
RFQ_TIMING_WINDOW_DAYS=30

# Shared retry controls for provider calls
RFQ_LLM_MAX_RETRIES=2
RFQ_LLM_RETRY_BASE_MS=1000

# -------- Together AI --------
TOGETHER_API_KEY="your-together-api-key"
TOGETHER_BASE_URL="https://api.together.xyz/v1"
TOGETHER_MODEL="mistralai/Mistral-Nemo-Instruct-2407"
# Optional per-task overrides:
# TOGETHER_CLASSIFIER_MODEL="mistralai/Mistral-Nemo-Instruct-2407"
# TOGETHER_EXTRACTION_MODEL="mistralai/Mistral-Nemo-Instruct-2407"

# -------- Mistral AI --------
MISTRAL_API_KEY="your-mistral-api-key"
MISTRAL_BASE_URL="https://api.mistral.ai/v1"
MISTRAL_MODEL="open-mistral-nemo"
# Optional per-task overrides:
# MISTRAL_CLASSIFIER_MODEL="open-mistral-nemo"
# MISTRAL_EXTRACTION_MODEL="open-mistral-nemo"

# -------- DeepSeek --------
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
# Optional per-task overrides:
# DEEPSEEK_CLASSIFIER_MODEL="deepseek-chat"
# DEEPSEEK_EXTRACTION_MODEL="deepseek-chat"

# -------- OpenRouter (optional provider) --------
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1/chat/completions"
OPENROUTER_MODEL="openrouter/owl-alpha"
# Optional per-task overrides:
# OPENROUTER_CLASSIFIER_MODEL="openrouter/owl-alpha"
# OPENROUTER_EXTRACTION_MODEL="openrouter/owl-alpha"

# -------- Groq (1st fallback by default) --------
GROQ_API_KEY="your-groq-api-key"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="openai/gpt-oss-20b"
# Optional per-task overrides:
# GROQ_CLASSIFIER_MODEL="openai/gpt-oss-20b"
# GROQ_EXTRACTION_MODEL="openai/gpt-oss-20b"

# -------- Cerebras (2nd fallback by default) --------
CEREBRAS_API_KEY="your-cerebras-api-key"
CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"
CEREBRAS_MODEL="gpt-oss-120b"
# Optional per-task overrides:
# CEREBRAS_CLASSIFIER_MODEL="gpt-oss-120b"
# CEREBRAS_EXTRACTION_MODEL="gpt-oss-120b"

# -------- Gemini (3rd fallback by default) --------
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/models"
GEMINI_MODEL="gemini-2.5-flash-lite"
# Optional per-task overrides:
# GEMINI_CLASSIFIER_MODEL="gemini-2.5-flash-lite"
# GEMINI_EXTRACTION_MODEL="gemini-2.5-flash-lite"

# ============================================
# OPTIONAL: DATABASE LOGGING (Development Only)
# ============================================
# Set DATABASE_LOG=true to see SQL queries in console during development
# DATABASE_LOG="true"

# ============================================
# REDIS (Bull job queue)
# ============================================
# Redis connection URL for Bull job queues
REDIS_URL=redis://localhost:6379

# ============================================
# GMAIL PUB/SUB PUSH NOTIFICATIONS (optional)
# ============================================
# Create a Pub/Sub topic in Google Cloud Console, then set its full resource name here.
# Format: projects/<project-id>/topics/<topic-name>
# Leave blank to use polling fallback only.
GMAIL_PUBSUB_TOPIC=

# ============================================
# OUTLOOK / OFFICE 365 INTEGRATION
# ============================================
# Register an app in Azure Active Directory (App registrations)
# Grant permissions: Mail.Read, Mail.Send, offline_access
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:3001/api/email-integrations/outlook/callback
# Use 'common' for multi-tenant, or your specific tenant GUID/domain
OUTLOOK_TENANT=common

# ============================================
# META (WhatsApp Business API)
# ============================================
# Create a Meta app at https://developers.facebook.com
# Enable WhatsApp product and get credentials from the dashboard
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
# A secret string you choose; must match what you enter in the Meta webhook verification step
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_REDIRECT_URI=http://localhost:3001/api/whatsapp/meta/callback
