# Database
DATABASE_URL=postgresql://user:password@host:5432/database_name

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Backend URL (for frontend API calls)
REACT_APP_API_URL=https://your-backend.railway.app/api

# Gmail OAuth (optional - for email integration)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=https://your-backend.railway.app/api/email-integrations/oauth/callback

# OpenAI API (for RFQ processing)
OPENAI_API_KEY=sk-your-openai-api-key
LLM_PROVIDER=openai

# Auto Features
AUTO_EMAIL_SYNC_ENABLED=true
AUTO_SEND_QUOTATION=true
BACKEND_RFQ_PIPELINE_ENABLED=true
BACKEND_RFQ_PIPELINE_INTERVAL_MS=20000

# Email Sync
RFQ_PIPELINE_BATCH_LIMIT=60
RFQ_CLASSIFIER_BATCH_SIZE=8
RFQ_EXTRACT_DELAY_MS=250

# Optional: Claude/Anthropic
ANTHROPIC_API_KEY=your-anthropic-key

# Optional: Google Gemini
GOOGLE_AI_API_KEY=your-google-ai-key
